###############################
# Unreal Engine Project Files #
###############################

# Engine-generated project files
*.xcodeproj
*.xcworkspace
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb
.vsconfig

# Unreal build artifacts
Binaries/
Build/
Intermediate/
DerivedDataCache/
Saved/

# Plugin build artifacts
Plugins/**/Binaries/
Plugins/**/Intermediate/

# Map build data
*_BuiltData.uasset

# Precompiled assets
SourceArt/**/*.png
SourceArt/**/*.tga

# Cache files
DerivedDataCache/*

# Autosaves & logs
Saved/Autosaves/*
Saved/Logs/*

#################################
# Visual Studio / Compiler Junk #
#################################

# Visual Studio user-specific files
.vs/

# Compiled object files
*.slo
*.lo
*.o
*.obj

# Precompiled headers
*.gch
*.pch

# Compiled dynamic libraries
*.so
*.dylib
*.dll

# Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app
*.ipa

# User-specific files
*.user
*.userprefs
*.log
*.tlog

# Backup files
*.bak
*.tmp

###############################
# JetBrains Rider / IntelliJ  #
###############################

.idea/
*.ipr
*.iws
*.iml

########################################
# Build Folder Exceptions (Unreal Rule) #
########################################

# Whitelist PakBlacklist-<BuildConfiguration>.txt files
!Build/*/
Build/*/**
!Build/*/PakBlacklist*.txt

# Don't ignore icon files in Build
!Build/**/*.ico

###################################
# Local Config Overrides (Optional)
###################################

Config/DefaultEditorPerProjectUserSettings.ini
Config/DefaultEditorUserSettings.ini
